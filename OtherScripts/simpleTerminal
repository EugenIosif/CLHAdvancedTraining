import serial
import time
import random

ser = serial.Serial(
    port='COM9',
    baudrate=115200,
    parity=serial.PARITY_NONE,
    stopbits=serial.STOPBITS_ONE,
    bytesize=serial.EIGHTBITS
)

while True:
    if(ser.in_waiting > 0):
        bs = ser.read(ser.in_waiting)  # Clear the buffer
        print("\n", bs.hex())
        time.sleep(0.5)
    
